meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/login
  body: json
  auth: none
}

body:json {
  {
    "email": "alice@example.com",
    "password": "secret123"
  }
}

vars:pre-request {
  baseUrl: http://localhost:8080/api/v1
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token", res.body.token);
  }
}
