meta {
  name: Create Team
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/teams
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "Backend Squad"
  }
}

vars:pre-request {
  baseUrl: http://localhost:8080/api/v1
